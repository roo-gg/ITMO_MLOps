# Copy this file to .env after ClearML Server is running.
# Create keys in ClearML UI: Settings -> Workspace -> Create new credentials.

CLEARML_API_ACCESS_KEY=replace_me
CLEARML_API_SECRET_KEY=replace_me

CLEARML_API_HOST=http://localhost:8008
CLEARML_WEB_HOST=http://localhost:8090

# The fileserver URL must be reachable from Docker containers that download model artifacts.
# On Windows with Docker Desktop, host.docker.internal points from containers to the host.
CLEARML_FILES_HOST=http://host.docker.internal:8081

CLEARML_PROJECT=MLOps-Course
CLEARML_QUEUE=students

# Set after: clearml-serving create --name textflow-serving
CLEARML_SERVING_TASK_ID=replace_after_serving_create

SERVING_ENDPOINT=http://localhost:8082/serve/text-sentiment
UI_PORT=7860